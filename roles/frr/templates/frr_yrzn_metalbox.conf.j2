frr version {{ frr_version }}
frr defaults traditional
hostname {{ frr_hostname }}
no ipv6 forwarding
service integrated-vtysh-config
!
ip prefix-list DEFAULT-ONLY seq 5 permit 0.0.0.0/0

route-map BMC-FILTER-IN deny 10
 match ip address prefix-list DEFAULT-ONLY

route-map BMC-FILTER-IN permit 20

route-map BMC-redistribute-loopback permit 100
        match interface {{ frr_yrzn_metalbox_bmc_loopback }}
exit

route-map BMC-FILTER-OUT permit 100
        match interface {{ frr_yrzn_metalbox_bmc_loopback }}
exit

route-map DATA-redistribute-loopback permit 100
        match interface {{ frr_yrzn_metalbox_data_loopback }}
exit

route-map DATA-FILTER-IN permit 100

route-map DATA-FILTER-OUT permit 100
        match interface {{ frr_yrzn_metalbox_data_loopback }}
exit

router bgp {{ frr_yrzn_metalbox_data_as }} vrf {{ frr_yrzn_metalbox_data_vrf }}
        bgp router-id {{ frr_yrzn_metalbox_data_router_id }}
        bgp bestpath as-path multipath-relax
        neighbor {{ frr_yrzn_metalbox_data_peer_group }} peer-group
        neighbor {{ frr_yrzn_metalbox_data_peer_group }} remote-as external
        neighbor {{ frr_yrzn_metalbox_data_peer_group }} timers connect {{ frr_yrzn_metalbox_timers_connect }}
        neighbor {{ frr_yrzn_metalbox_data_peer_group }} timers {{ frr_yrzn_metalbox_timers_keepalive }} {{ frr_yrzn_metalbox_timers_holdtime }}
{% if frr_yrzn_metalbox_data_password is defined and frr_yrzn_metalbox_data_password %}
        neighbor {{ frr_yrzn_metalbox_data_peer_group }} password {{ frr_yrzn_metalbox_data_password }}
{% endif %}
        no neighbor {{ frr_yrzn_metalbox_data_peer_group }} send-community
        address-family ipv4 unicast
                maximum-paths {{ frr_yrzn_metalbox_maximum_paths }}
                redistribute connected route-map DATA-redistribute-loopback
                neighbor {{ frr_yrzn_metalbox_data_peer_group }} route-map DATA-FILTER-IN in
                neighbor {{ frr_yrzn_metalbox_data_peer_group }} route-map DATA-FILTER-OUT out
        exit-address-family
{% for item in frr_uplinks_data %}
        neighbor {{ item.interface }} interface peer-group {{ frr_yrzn_metalbox_data_peer_group }}
{% endfor %}

router bgp {{ frr_local_as }}
        bgp router-id {{ frr_loopback_v4 }}
        bgp bestpath as-path multipath-relax
        neighbor {{ frr_yrzn_metalbox_bmc_peer_group }} peer-group
        neighbor {{ frr_yrzn_metalbox_bmc_peer_group }} remote-as external
        neighbor {{ frr_yrzn_metalbox_bmc_peer_group }} timers connect {{ frr_yrzn_metalbox_timers_connect }}
        neighbor {{ frr_yrzn_metalbox_bmc_peer_group }} timers {{ frr_yrzn_metalbox_timers_keepalive }} {{ frr_yrzn_metalbox_timers_holdtime }}
{% if frr_yrzn_metalbox_bmc_password is defined and frr_yrzn_metalbox_bmc_password %}
        neighbor {{ frr_yrzn_metalbox_bmc_peer_group }} password {{ frr_yrzn_metalbox_bmc_password }}
{% endif %}
        no neighbor {{ frr_yrzn_metalbox_bmc_peer_group }} send-community
        address-family ipv4 unicast
                maximum-paths {{ frr_yrzn_metalbox_maximum_paths }}
                redistribute connected route-map BMC-redistribute-loopback
                neighbor {{ frr_yrzn_metalbox_bmc_peer_group }} route-map BMC-FILTER-IN in
                neighbor {{ frr_yrzn_metalbox_bmc_peer_group }} route-map BMC-FILTER-OUT out
        exit-address-family
{% for item in frr_uplinks_bmc %}
        neighbor {{ item.interface }} interface peer-group {{ frr_yrzn_metalbox_bmc_peer_group }}
{% endfor %}
